{
  "name": "markdown-paddleocr-plainer",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "tsc --noEmit --strict",
    "dev": "bun run index.ts",
    "bundle": "bun build ./index.ts --minify --minify-whitespace --minify-identifiers --minify-syntax --bytecode --sourcemap --format=esm --compile --compile-autoload-tsconfig --compile-autoload-package-json --outfile ./release/markdown-paddleocr-plainer",
    "bundle:windows": "bun build ./index.ts --minify --minify-whitespace --minify-identifiers --minify-syntax --bytecode --sourcemap --format=esm --compile --windows-hide-console --compile-autoload-tsconfig --compile-autoload-package-json --outfile ./release/markdown-paddleocr-plainer.exe"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@webviewjs/webview": "^0.2.1",
    "string-strip-html": "^13.5.3"
  }
}
